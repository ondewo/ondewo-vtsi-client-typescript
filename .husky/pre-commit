#!/bin/sh

set -e
make eslint
make prettier PRETTIER_WRITE=-w
# Run pre-commit hooks on a normal dev commit, but SKIP during automated release
# codegen, which leaves .pre-commit-config.yaml unstaged and makes `pre-commit run`
# abort with "Your pre-commit configuration is unstaged".
if command -v pre-commit >/dev/null 2>&1 && git diff --quiet -- .pre-commit-config.yaml 2>/dev/null; then
  pre-commit run
fi
