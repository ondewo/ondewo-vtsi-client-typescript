# ONDEWO VTSI TypeScript client - examples configuration.
#
# TEMPLATE ONLY: contains non-secret placeholders and MUST NOT hold real credentials.
# Every runnable example loads this file via dotenv, with the path resolved relative to the
# script, so it works regardless of the current working directory. Fill in the blank values
# for your deployment before running an example.

# --- Connection: VTSI gRPC-web endpoint ---
# The example builds the gRPC-web URL as "<scheme>://ONDEWO_HOST:ONDEWO_PORT", where the
# scheme is "https" when ONDEWO_USE_SECURE_CHANNEL=true and "http" otherwise.
ONDEWO_HOST=localhost
ONDEWO_PORT=443

# --- Secure channel ---
# Use a TLS (https) gRPC-web channel: "true" (secure) or "false".
ONDEWO_USE_SECURE_CHANNEL=true

# --- Keycloak: D18 headless-SDK offline-token login ---
# Base Keycloak URL (trailing slash and an "/auth" suffix are both tolerated).
KEYCLOAK_URL=https://localhost/auth
KEYCLOAK_REALM=ondewo-ccai-platform
# Public headless-SDK client id (no client secret). The technical user must be 2FA-exempt.
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# Technical-user credentials (leave blank in this template; provide real values locally).
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak TLS certificate: "true" (secure) or "false" (self-signed local Envoy only).
KEYCLOAK_VERIFY_SSL=true
